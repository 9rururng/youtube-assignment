<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <title>과제 제출 영상</title>
  <style>
    body { background:#111; color:#fff; font-family:sans-serif; padding:20px; }
    .grid { display:grid; grid-template-columns:repeat(auto-fill, minmax(250px,1fr)); gap:20px; }
    .card { background:#1c1c1c; border-radius:10px; overflow:hidden; }
    img { width:100%; }
    .info { padding:10px; }
  </style>
</head>
<body>

<h2>🎸 과제 제출</h2>
<div class="grid" id="videoList"></div>

<script>
const sheetURL = "https://docs.google.com/spreadsheets/d/1kTpj8r_CAJTbxjRgtbF2YZ4rOXsB9shoZ2YPO6o8wzE/edit?usp=sharing";

fetch(sheetURL)
  .then(res => res.json())
  .then(data => {
    const rows = data.values.slice(1);

    // 최신순 정렬 (날짜 기준)
    rows.sort((a, b) => new Date(b[0]) - new Date(a[0]));

    rows.forEach(row => {
      const date = row[0];
      const name = row[1];
      const url = row[2];

      if (!url) return;

      let videoId;

      if (url.includes("youtu.be")) {
        videoId = url.split("/").pop().split("?")[0];
      } else {
        videoId = url.split("v=")[1]?.split("&")[0];
      }

      const thumb = `https://img.youtube.com/vi/${videoId}/0.jpg`;

      const card = `
        <div class="card">
          <a href="${url}" target="_blank">
            <img src="${thumb}">
          </a>
          <div class="info">
            <div>${name}</div>
            <div style="font-size:12px;color:#aaa;">${date}</div>
          </div>
        </div>
      `;

      document.getElementById("videoList").innerHTML += card;
    });
  });
</script>

</body>
</html>
